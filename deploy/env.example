# Пример переменных окружения (образец .env).
# Реальный .env генерирует установщик со случайными секретами — этот файл
# нужен только для ручной отладки. Скопируйте в `.env` и заполните.

# --- OpenClaw ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=change-me-random-32
OPENCLAW_SANDBOX=1
TELEGRAM_BOT_TOKEN=123456:ABC-YOUR-BOT-TOKEN

# --- OmniRoute ---
OMNIROUTE_PORT=20128
INITIAL_PASSWORD=change-me
JWT_SECRET=change-me-openssl-rand-base64-48
API_KEY_SECRET=change-me-32
STORAGE_ENCRYPTION_KEY=change-me-32
OMNIROUTE_ENABLE_FREE_MODELS=true
